{
  "name": "pm-tech-radar",
  "version": "0.1.0",
  "description": "Automated weekly research digest for PM, architecture, and technical leadership",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "manifest": "tsx src/generate-manifest.ts",
    "rollup:weekly": "tsx src/weekly.ts",
    "rollup:monthly": "tsx src/monthly.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1078.0",
    "fast-xml-parser": "^4.5.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.73.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
